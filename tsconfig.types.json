{
    "compilerOptions": {
        "allowJs": true,
        "checkJs": false,
        "declaration": true,
        "emitDeclarationOnly": true,
        "declarationDir": "./types",
        "rootDir": ".",
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node10",
        "ignoreDeprecations": "6.0",
        "skipLibCheck": true,
        "strictNullChecks": true
    },
    "include": [
        "lib/index.js",
        "lib/lab.js",
        "lib/psi.js",
        "lib/crux.js",
        "lib/crux-history.js",
        "lib/utils.js",
        "lib/profiles.js",
        "lib/strip-props.js",
        "lib/logger.js",
        "lib/prompts.js",
        "lib/links.js",
        "lib/sitemap.js"
    ],
    "exclude": [
        "node_modules",
        "**/*.test.js"
    ]
}
